# =============================================================
# TriForge · .gitignore
# =============================================================
# 1) Python build / cache artifacts
# -------------------------------------------------------------
__pycache__/                 # CPython bytecode cache
*.py[cod]                    # .pyc .pyo .pyd
*$py.class                   # inner-class bytecode
*.so                         # C extensions

# 2) Virtual env
# -------------------------------------------------------------
.venv/
venv/
env/
.venv-*/

# 3) Test / type-checker / linter caches
# -------------------------------------------------------------
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
.coverage.*
htmlcov/
.pytest_cache/

# 4) Distribution / build outputs
# -------------------------------------------------------------
build/
dist/
*.egg-info/
*.egg
.eggs/
pip-wheel-metadata/

# 5) Logs and runtime state
# -------------------------------------------------------------
logs/*.log
logs/*.err.log
logs/server.pid
.env
.env.local
.env.*.local

# 6) SQLite database (auto-generated by the app on first run)
# -------------------------------------------------------------
data/*.db
data/*.db-journal
data/*.db-wal
data/*.db-shm

# 7) Runtime settings — contains API keys, never commit
# -------------------------------------------------------------
data/settings.json
data/settings.json.bak
data/settings.local.json
data/*.bak

# 8) Run workspaces (per-run code artifacts)
# -------------------------------------------------------------
workspace/design/*
workspace/src/*
workspace/tests/*
!workspace/design/.gitkeep
!workspace/src/.gitkeep
!workspace/tests/.gitkeep
workspace/*/design/*
workspace/*/src/*
workspace/*/tests/*

# 9) IDE / editor directories
# -------------------------------------------------------------
.idea/
.vscode/
*.swp
*.swo
*~

# 10) OS detritus
# -------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini
$RECYCLE.BIN/

# 11) Local secrets / overrides (anything with "local", "secret",
#     or "private" in the name) — adjust patterns as needed
# -------------------------------------------------------------
**/secrets.local.*
**/*.local.*
**/private.*
.triforge.local.json
# 12) Leftover artifacts that escaped earlier patterns
logs/*
!logs/.gitkeep
# 13) Per-run output dirs (agent creates workspace/run_<uuid>/)
workspace/run_*/
!workspace/run_*/.gitkeep
